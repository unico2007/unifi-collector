# Copy this file to .env and fill in real values, then run: docker compose up -d
# .env is gitignored so secrets never get committed.

# --- UniFi controller ---
UNIFI_URL=https://10.10.0.3
UNIFI_USERNAME=your-readonly-user
UNIFI_PASSWORD=change-me

# --- Grafana admin login (http://<server-ip>:3000) ---
GRAFANA_PASSWORD=change-me

# --- Kerio Control firewall (optional 2nd vendor). Set KERIO_ENABLED=true to use. ---
KERIO_ENABLED=false
KERIO_URL=https://10.10.0.1:4081
KERIO_USERNAME=Admin
KERIO_PASSWORD=change-me

# --- GHCR pull auth (ONLY for the prod stack when the image package is PRIVATE) ---
# Create a GitHub token with read:packages scope. Leave blank if the package is public.
GHCR_USER=unico2007
GHCR_TOKEN=

# --- AI assistant model (optional). Priority: Gemini > NVIDIA > local Ollama. ---
# Google Gemini (recommended): fast, good Azerbaijani, OpenAI-compatible. Get a key
# at https://aistudio.google.com/apikey (free tier works; paid = no training on data).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
# NVIDIA NIM (alternative cloud model). Used only if GEMINI_API_KEY is empty.
NVIDIA_API_KEY=
# Answer language override; empty = auto (Azerbaijani when a cloud key is set).
AI_ANSWER_LANG=
